{
  "permissions": {
    "allow": [
      "Read(**/.agent/**)",
      "Edit(**/.agent/**)",
      "Write(**/.agent/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/self-maintenance.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 $HOME/.claude/hooks/self-maintenance.py"
          }
        ]
      }
    ]
  }
}
